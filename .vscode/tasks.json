{
    "version": "2.0.0",
    "tasks": [
        // ====================================================================
        // SRC NODE (Sender) - /dev/cu.usbmodem211101
        // ====================================================================
        {
            "label": "SRC: Build",
            "type": "shell",
            "command": "pio run -e src",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": { "panel": "shared" }
        },
        {
            "label": "SRC: Upload Firmware",
            "type": "shell",
            "command": "pio run -e src -t upload --upload-port /dev/cu.usbmodem211101",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": { "panel": "shared" }
        },
        {
            "label": "SRC: Upload Filesystem (SPIFFS)",
            "type": "shell",
            "command": "pio run -e src -t uploadfs --upload-port /dev/cu.usbmodem211101",
            "group": "build",
            "problemMatcher": [],
            "presentation": { "panel": "shared" }
        },
        {
            "label": "SRC: Monitor",
            "type": "shell",
            "command": "pio device monitor -b 115200 --port /dev/cu.usbmodem211101",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": { "panel": "dedicated", "focus": true }
        },
        {
            "label": "SRC: Build + Upload + Monitor",
            "dependsOrder": "sequence",
            "dependsOn": ["SRC: Build", "SRC: Upload Firmware", "SRC: Monitor"],
            "problemMatcher": []
        },

        // ====================================================================
        // OUT NODES (Receivers)
        // ====================================================================
        {
            "label": "OUT: Build",
            "type": "shell",
            "command": "pio run -e out",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": { "panel": "shared" }
        },
        
        // OUT 1: 21201
        {
            "label": "OUT 1: Upload Firmware (21201)",
            "type": "shell",
            "command": "pio run -e out -t upload --upload-port /dev/cu.usbmodem21201",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "OUT 1: Upload SPIFFS (21201)",
            "type": "shell",
            "command": "pio run -e out -t uploadfs --upload-port /dev/cu.usbmodem21201",
            "problemMatcher": []
        },

        // OUT 2: 21301
        {
            "label": "OUT 2: Upload Firmware (21301)",
            "type": "shell",
            "command": "pio run -e out -t upload --upload-port /dev/cu.usbmodem21301",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },

        // OUT 3: 21401
        {
            "label": "OUT 3: Upload Firmware (21401)",
            "type": "shell",
            "command": "pio run -e out -t upload --upload-port /dev/cu.usbmodem21401",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },

        // Bulk Operations
        {
            "label": "OUT: Upload All (3 Nodes)",
            "type": "shell",
            "command": "pio run -e out -t upload --upload-port /dev/cu.usbmodem21201 && pio run -e out -t upload --upload-port /dev/cu.usbmodem21301 && pio run -e out -t upload --upload-port /dev/cu.usbmodem21401",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "OUT: Upload SPIFFS All (3 Nodes)",
            "type": "shell",
            "command": "pio run -e out -t uploadfs --upload-port /dev/cu.usbmodem21201 && pio run -e out -t uploadfs --upload-port /dev/cu.usbmodem21301 && pio run -e out -t uploadfs --upload-port /dev/cu.usbmodem21401",
            "problemMatcher": []
        },

        // ====================================================================
        // GENERAL / UTILITY
        // ====================================================================
        {
            "label": "Build All (SRC + OUT)",
            "type": "shell",
            "command": "pio run -e src && pio run -e out",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Clean All",
            "type": "shell",
            "command": "pio run -t clean -e src -e out",
            "problemMatcher": []
        },
        {
            "label": "Test Native",
            "type": "shell",
            "command": "pio test -e native",
            "group": "test",
            "problemMatcher": ["$gcc"]
        }
    ]
}
