                "panel": "shared"
            }
        },
        {
            "label": "RX: Upload",
            "type": "shell",
            "command": "pio run -e rx -t upload --upload-port /dev/cu.usbmodem2101",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "RX: Monitor",
            "type": "shell",
            "command": "pio device monitor -b 115200 --port /dev/cu.usbmodem2101",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated"
            }
        },
        {
            "label": "RX: Build + Upload + Monitor",
            "dependsOrder": "sequence",
            "dependsOn": [
                "RX: Build",
                "RX: Upload",
                "RX: Monitor"
            ],
            "problemMatcher": []
        },

        // COMBO Tasks
        {
            "label": "COMBO: Build",
            "type": "shell",
            "command": "pio run -e combo",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "COMBO: Upload",
            "type": "shell",
            "command": "pio run -e combo -t upload --upload-port /dev/cu.usbmodem101",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "COMBO: Upload SPIFFS",
            "type": "shell",
            "command": "pio run -e combo -t uploadfs --upload-port /dev/cu.usbmodem21401",
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "COMBO: Monitor",
            "type": "shell",
            "command": "pio device monitor -b 115200 --port /dev/cu.usbmodem101",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated"
            }
        },
        {
            "label": "COMBO: Build + Upload + Monitor",
            "dependsOrder": "sequence",
            "dependsOn": [
                "COMBO: Build",
                "COMBO: Upload",
                "COMBO: Monitor"
            ],
            "problemMatcher": []
        },

        // Both devices
        {
            "label": "Build All (TX + RX + COMBO)",
            "type": "shell",
            "command": "pio run -e tx -e rx -e combo",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "rm -rf .pio/build && pio run -e tx -e rx -e combo",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },

        // Flash All Test Nodes
        {
            "label": "Erase All Test Nodes",
            "type": "shell",
            "command": "~/.platformio/packages/tool-esptoolpy/esptool.py --chip esp32s3 --port /dev/cu.usbmodem21401 erase_flash && ~/.platformio/packages/tool-esptoolpy/esptool.py --chip esp32s3 --port /dev/cu.usbmodem211101 erase_flash && ~/.platformio/packages/tool-esptoolpy/esptool.py --chip esp32s3 --port /dev/cu.usbmodem211201 erase_flash && ~/.platformio/packages/tool-esptoolpy/esptool.py --chip esp32s3 --port /dev/cu.usbmodem211301 erase_flash",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Upload All Test Nodes",
            "type": "shell",
            "command": "pio run -e combo -t upload --upload-port /dev/cu.usbmodem21401 && pio run -e combo -t uploadfs --upload-port /dev/cu.usbmodem21401 && pio run -e rx -t upload --upload-port /dev/cu.usbmodem211101 && pio run -e rx -t upload --upload-port /dev/cu.usbmodem211201 && pio run -e rx -t upload --upload-port /dev/cu.usbmodem211301",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Erase + Upload All Test Nodes",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Erase All Test Nodes",
                "Upload All Test Nodes"
            ],
            "problemMatcher": []
        }
    ]
}
