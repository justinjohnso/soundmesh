# Required runtime evidence markers for enabling portal flags in build.h.
# Copy to portal-enable-evidence.env and fill with measured values from latest HIL run.
# Gate checks this file only when ENABLE_SRC_USB_PORTAL_NETWORK=1 or ENABLE_OUT_USB_PORTAL_NETWORK=1.

PORTAL_ENABLE_APPROVED=NO
EVIDENCE_UTC=2026-03-23T00:00:00Z
EVIDENCE_COMMIT=<git-commit-sha>

# Must match build.h portal flags exactly (0 or 1)
PORTAL_SRC_FLAG=0
PORTAL_OUT_FLAG=0

# Runtime smoke evidence (minimum thresholds enforced by gate)
PORTAL_STATUS_200_OK_RUNS=0
TX_FREE_HEAP_MIN_BYTES=0
COMBO_FREE_HEAP_MIN_BYTES=0
RX_FREE_HEAP_MIN_BYTES=0
TX_MAIN_STACK_HWM_MIN_BYTES=0
COMBO_MAIN_STACK_HWM_MIN_BYTES=0
RX_MAIN_STACK_HWM_MIN_BYTES=0

# HIL soak evidence (required when portal flags are enabled)
# Generate via:
# python tools/hil_soak_check.py --src-port /dev/cu.usbmodem101 --out-port /dev/cu.usbmodem1101 --duration 120
PORTAL_HIL_DURATION_SECONDS=0
PORTAL_HIL_IGNORE_RESET_WINDOW_SECONDS=0
PORTAL_HIL_SRC_PANIC_HITS=0
PORTAL_HIL_OUT_PANIC_HITS=0
PORTAL_HIL_SRC_LATE_RESET_HITS=0
PORTAL_HIL_OUT_LATE_RESET_HITS=0
PORTAL_HIL_SRC_OK_HITS=0
PORTAL_HIL_OUT_OK_HITS=0
