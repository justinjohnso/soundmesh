<section class="pane pane-mixer">
  <div class="pane-title"><span id="mixer-pane-title">MIXER</span></div>

  <div class="mixer-block">
    <div class="mixer-block-label">MASTER OUTPUT</div>
    <div class="mixer-row">
      <input id="master-out-gain-slider" class="fader" type="range"
             min="0" max="400" step="1" value="200"
             aria-label="Master output gain percent" />
      <span id="master-out-gain-pct" class="fader-db">200%</span>
    </div>
  </div>

  <div class="mixer-block">
    <div class="mixer-block-label">STREAMS</div>

    <div class="stream-row" data-stream-id="1">
      <div class="stream-row-header">
        <span class="stream-row-title">STREAM 1</span>
        <span id="stream-1-state" class="stream-state">ACTIVE</span>
      </div>
      <div class="mixer-row">
        <input id="stream-1-gain-slider" class="fader stream-gain-slider" type="range"
               min="0" max="400" step="1" value="100"
               aria-label="Stream 1 gain percent" />
        <span id="stream-1-gain-pct" class="fader-db">100%</span>
      </div>
      <div class="stream-controls">
        <button id="stream-1-enable-btn" class="seg-btn stream-toggle-btn" type="button" aria-pressed="true">ENABLED</button>
        <button id="stream-1-mute-btn" class="mute-btn" type="button" aria-pressed="false">MUTE</button>
        <button id="stream-1-solo-btn" class="seg-btn stream-toggle-btn" type="button" aria-pressed="false">SOLO</button>
      </div>
    </div>

    <div class="stream-row" data-stream-id="2">
      <div class="stream-row-header">
        <span class="stream-row-title">STREAM 2</span>
        <span id="stream-2-state" class="stream-state">INACTIVE</span>
      </div>
      <div class="mixer-row">
        <input id="stream-2-gain-slider" class="fader stream-gain-slider" type="range"
               min="0" max="400" step="1" value="100"
               aria-label="Stream 2 gain percent" />
        <span id="stream-2-gain-pct" class="fader-db">100%</span>
      </div>
      <div class="stream-controls">
        <button id="stream-2-enable-btn" class="seg-btn stream-toggle-btn" type="button" aria-pressed="false">DISABLED</button>
        <button id="stream-2-mute-btn" class="mute-btn" type="button" aria-pressed="false">MUTE</button>
        <button id="stream-2-solo-btn" class="seg-btn stream-toggle-btn" type="button" aria-pressed="false">SOLO</button>
      </div>
    </div>

    <div class="stream-row" data-stream-id="3">
      <div class="stream-row-header">
        <span class="stream-row-title">STREAM 3</span>
        <span id="stream-3-state" class="stream-state">INACTIVE</span>
      </div>
      <div class="mixer-row">
        <input id="stream-3-gain-slider" class="fader stream-gain-slider" type="range"
               min="0" max="400" step="1" value="100"
               aria-label="Stream 3 gain percent" />
        <span id="stream-3-gain-pct" class="fader-db">100%</span>
      </div>
      <div class="stream-controls">
        <button id="stream-3-enable-btn" class="seg-btn stream-toggle-btn" type="button" aria-pressed="false">DISABLED</button>
        <button id="stream-3-mute-btn" class="mute-btn" type="button" aria-pressed="false">MUTE</button>
        <button id="stream-3-solo-btn" class="seg-btn stream-toggle-btn" type="button" aria-pressed="false">SOLO</button>
      </div>
    </div>

    <div class="stream-row" data-stream-id="4">
      <div class="stream-row-header">
        <span class="stream-row-title">STREAM 4</span>
        <span id="stream-4-state" class="stream-state">INACTIVE</span>
      </div>
      <div class="mixer-row">
        <input id="stream-4-gain-slider" class="fader stream-gain-slider" type="range"
               min="0" max="400" step="1" value="100"
               aria-label="Stream 4 gain percent" />
        <span id="stream-4-gain-pct" class="fader-db">100%</span>
      </div>
      <div class="stream-controls">
        <button id="stream-4-enable-btn" class="seg-btn stream-toggle-btn" type="button" aria-pressed="false">DISABLED</button>
        <button id="stream-4-mute-btn" class="mute-btn" type="button" aria-pressed="false">MUTE</button>
        <button id="stream-4-solo-btn" class="seg-btn stream-toggle-btn" type="button" aria-pressed="false">SOLO</button>
      </div>
    </div>
  </div>

  <!-- ── Latency Target (all roles) ──────────────────────────── -->
  <div class="mixer-block">
    <div class="mixer-block-label">LATENCY TARGET</div>
    <div class="seg-group">
      <button class="seg-btn latency-btn" type="button" data-frames="14">
        STABLE<br/><span class="seg-sub">~280ms</span>
      </button>
      <button class="seg-btn latency-btn" type="button" data-frames="4">
        BALANCED<br/><span class="seg-sub">~80ms</span>
      </button>
      <button class="seg-btn latency-btn" type="button" data-frames="2">
        LOW LAT<br/><span class="seg-sub">~40ms</span>
      </button>
    </div>
    <div id="latency-note" class="mixer-note">Lower latency increases dropout risk on noisy WiFi.</div>
  </div>

  <!-- ── Signal Meter / FFT ───────────────────────────────────── -->
  <div class="mixer-block">
    <div class="mixer-block-label">SIGNAL</div>
    <canvas id="fft-canvas" aria-label="Log frequency FFT"></canvas>
    <div class="fft-axis"><span>20Hz</span><span>20kHz</span></div>
  </div>

  <div class="mixer-block">
    <div class="mixer-block-label">UPTIME</div>
    <div id="uptime-value" class="uptime-value">0h 00m 00s</div>
  </div>

</section>
