<section class="pane pane-audio">
  <div class="pane-title">AUDIO ANALYSIS</div>
  <div class="bpm-block">
    <div class="label">Calculated BPM</div>
    <div class="bpm-value"><span id="bpm-value">126</span> BPM</div>
  </div>
  <div class="fft-block">
    <div class="label">FFT (Log Freq)</div>
    <canvas id="fft-canvas" aria-label="Log frequency FFT"></canvas>
    <div class="fft-axis"><span>20Hz</span><span>20kHz</span></div>
  </div>
  <div class="uptime-block">
    <div class="label">Uptime</div>
    <div id="uptime-value" class="uptime-value">0h 00m 00s</div>
  </div>
</section>
