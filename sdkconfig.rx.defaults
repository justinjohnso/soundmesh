# Console & logging
CONFIG_LOG_COLORS=n

# USB Serial JTAG console for XIAO ESP32-S3
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# I2S
CONFIG_I2S_ENABLE_TX_CHANNEL=y

# Stack size (8KB - main loop just polls buttons/display)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# FreeRTOS runtime stats (for portal Core 0 load telemetry)
CONFIG_FREERTOS_USE_TRACE_FACILITY=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y
